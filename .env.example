# Appwrite Configuration (Copy these to Settings > Secrets)
VITE_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=69d5b8c6001a776e6ebe
VITE_APPWRITE_DATABASE_ID=mlm_spiral

# Live Site Configuration
# Optional: Set this to your custom domain (e.g. https://decentralizedmlm.com)
# so referral and password reset links match the domain even if accessed via IP:PORT.
VITE_SITE_URL=

VITE_APPWRITE_USERS_COLLECTION_ID=users
VITE_APPWRITE_PACKAGES_COLLECTION_ID=packages
VITE_APPWRITE_PURCHASES_COLLECTION_ID=purchases
VITE_APPWRITE_WALLETS_COLLECTION_ID=wallets_
VITE_APPWRITE_TRANSACTIONS_COLLECTION_ID=transactions
VITE_APPWRITE_GOLD_QUEUE_COLLECTION_ID=gold_queue

# Appwrite Server (Secret) Key - Required for server-side operations
# Create this in Appwrite Console > Overview > API Keys
# REQUIRED SCOPES: documents.read, documents.write, users.read, users.write
APPWRITE_API_KEY=
