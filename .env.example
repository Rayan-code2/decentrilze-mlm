# Live Site Configuration
# Optional: Set this to your custom domain (e.g. https://decentralizedmlm.com)
# so referral and password reset links match the domain even if accessed via IP:PORT.
VITE_SITE_URL=

# PostgreSQL Connection details for server deployment
SQL_HOST=
SQL_PORT=
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=

# Schema admin credentials (for database migrations)
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=

# JWT Auth Secret Key
JWT_SECRET=
